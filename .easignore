# Files/directories to exclude from EAS build uploads
# When .easignore exists, EAS uses ONLY this file (not .gitignore)

# Dependencies (EAS runs npm ci to install fresh)
node_modules/
package-lock.json

# Git history
.git

# Expo cache
.expo/

# Migration scripts (not needed at runtime)
scripts/
*.sql

# Legacy/dev files
MAINTENANCE GUIDE.pdf
google-services.json
tsconfig.json
README.md
.env.local
# NOTE: Do NOT exclude .env — Expo needs it at build time to inline EXPO_PUBLIC_* variables

# Test scripts
check_pluto.js
test-fetch.mjs
test_elixir.js
test_sp.js
test_supabase.js
test_svg.js
test_svg_ids.js

# Build artifacts
dist/
web-build/

# Debug logs
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store

# Gemini/AI
.gemini/
